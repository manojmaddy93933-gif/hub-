{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information and role.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "mobileNumber": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Booking": {
      "title": "Service Booking",
      "description": "Record of a service booking (game, car wash, or badminton).",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["game", "carWash", "badminton"] },
        "resourceId": { "type": "string" },
        "resourceName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "duration": { "type": "number" },
        "vehicleNumber": { "type": "string" },
        "vehicleMake": { "type": "string" },
        "vehicleModel": { "type": "string" },
        "vehicleYear": { "type": "string" },
        "vehiclePhotoUrl": { "type": "string" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "ongoing", "completed", "cancelled"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "washPhase": { "type": "string", "enum": ["Queued", "In Progress", "Detailing", "Done"] },
        "price": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "date", "status", "price"]
    },
    "MenuItem": {
      "title": "Cafe Menu Item",
      "description": "Individual food or drink item in the cafe menu.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "isAvailable": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "price", "isAvailable"]
    },
    "Worker": {
      "title": "Hub Worker",
      "description": "Employee or worker at the hub.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "contact": { "type": "string" },
        "joiningDate": { "type": "string", "format": "date" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "role", "isActive"]
    },
    "Attendance": {
      "title": "Worker Attendance",
      "description": "Daily attendance record for a worker.",
      "type": "object",
      "properties": {
        "workerId": { "type": "string" },
        "workerName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "checkIn": { "type": "string", "format": "date-time" },
        "checkOut": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["present", "absent", "half-day"] },
        "notes": { "type": "string" }
      },
      "required": ["workerId", "workerName", "date", "status"]
    },
    "StaffSchedule": {
      "title": "Staff Schedule",
      "description": "Shift and service assignment for a worker.",
      "type": "object",
      "properties": {
        "workerId": { "type": "string" },
        "workerName": { "type": "string" },
        "workerRole": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "shift": { "type": "string", "enum": ["morning", "evening", "night", "full-day"] },
        "serviceType": { "type": "string", "enum": ["game", "carWash", "badminton", "theatre", "cafe"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["workerId", "workerName", "date", "shift"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles and metadata."
    },
    "bookings/{bookingId}": {
      "schema": "Booking",
      "description": "All service bookings across the hub."
    },
    "menu/{menuId}": {
      "schema": "MenuItem",
      "description": "Cafe menu catalog."
    },
    "workers/{workerId}": {
      "schema": "Worker",
      "description": "Records of all hub employees."
    },
    "attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Daily attendance logs."
    },
    "schedules/{scheduleId}": {
      "schema": "StaffSchedule",
      "description": "Staff shift and assignment plans."
    }
  }
}
